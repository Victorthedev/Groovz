# ─── Core ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=""
ENCRYPTION_KEY=""
NODE_ENV="production"

# ─── URLs ─────────────────────────────────────────────────────────────────────
# API's own public URL (used for OAuth callbacks)
API_BASE_URL=""          # e.g. https://groovz-api.up.railway.app

# Frontend URL (used for CORS and Socket.io)
WEB_BASE_URL=""          # e.g. https://groovz.vercel.app

# ─── Database & Cache ─────────────────────────────────────────────────────────
# Railway injects these automatically when you link the services
DATABASE_URL=""
REDIS_URL=""

# ─── Music APIs ───────────────────────────────────────────────────────────────
LASTFM_API_KEY=""

# ─── AI ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=""
HUGGINGFACE_API_KEY=""   # for embeddings (sentence-transformers)

# ─── Spotify ──────────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# ─── Deezer ───────────────────────────────────────────────────────────────────
DEEZER_APP_ID=""
DEEZER_APP_SECRET=""

# ─── YouTube Music ────────────────────────────────────────────────────────────
YOUTUBE_MUSIC_CLIENT_ID=""
YOUTUBE_MUSIC_CLIENT_SECRET=""

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# One Price ID per region — create recurring monthly prices in Stripe dashboard
STRIPE_PRICE_NG=""       # ₦2,500/month
STRIPE_PRICE_UK=""       # £3.99/month
STRIPE_PRICE_EU=""       # €4.49/month
STRIPE_PRICE_US=""       # $4.99/month
STRIPE_PRICE_CA=""       # CA$6.49/month

# ─── Crypto billing (v2) ──────────────────────────────────────────────────────
CRYPTO_CONTRACT_ADDRESS=""
